rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // 0. GLOBAL HELPERS
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // 1. VALIDATION HELPERS
    // -------------------------------------------------------------------------

    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email is string && data.email.size() <= 256
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128))
        && (!('rhythmStreak' in data) || (data.rhythmStreak is int && data.rhythmStreak >= 0))
        && (!('totalFocusHours' in data) || (data.totalFocusHours is number && data.totalFocusHours >= 0))
        && (!('nurtureLevel' in data) || (data.nurtureLevel is int && data.nurtureLevel >= 0))
        && (!('growthEnergy' in data) || (data.growthEnergy is number && data.growthEnergy >= 0));
    }

    function isValidTask(data) {
      return data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 512 && data.title.size() > 0
        && data.status in ['pending', 'in-progress', 'completed']
        && (!('category' in data) || (data.category is string && data.category.size() <= 128))
        && (!('priority' in data) || (data.priority in ['Low', 'Medium', 'High']))
        && (!('dueDate' in data) || (data.dueDate is timestamp));
    }

    function isValidThought(data) {
      return data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 512 && data.title.size() > 0
        && (!('content' in data) || (data.content is string && data.content.size() <= 1048576)) // 1MB content limit
        && (!('summary' in data) || (data.summary is string && data.summary.size() <= 1024))
        && (!('tags' in data) || (data.tags is list && data.tags.size() <= 20))
        && (!('category' in data) || (data.category is string && data.category.size() <= 128))
        && (!('wordCount' in data) || (data.wordCount is int && data.wordCount >= 0))
        && (!('isPinned' in data) || (data.isPinned is bool));
    }

    function isValidFocusSession(data) {
      return data.userId == request.auth.uid
        && (!('initiative' in data) || (data.initiative is string && data.initiative.size() <= 256))
        && (!('category' in data) || (data.category is string && data.category.size() <= 128))
        && data.durationSeconds is int && data.durationSeconds >= 0
        && data.startTime is timestamp
        && (!('endTime' in data) || (data.endTime is timestamp))
        && (!('quality' in data) || (data.quality in ['Low', 'Moderate', 'High', 'Peak', 'Focused', 'Sustained']))
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 1024));
    }

    function isValidGrowthArea(data) {
      return data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 256 && data.name.size() > 0
        && data.level is int && data.level >= 0
        && data.growthProgress is int && data.growthProgress >= 0 && data.growthProgress <= 100
        && data.category in ['Technical', 'Creative', 'Operational', 'Strategic', 'Human', 'Wellness']
        && data.stage in ['Seedling', 'Sprouting', 'Rooted', 'Budding', 'Full Bloom']
        && (!('lastTended' in data) || (data.lastTended is timestamp));
    }

    // -------------------------------------------------------------------------
    // 2. DEFAULT DENY
    // -------------------------------------------------------------------------

    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // 3. COLLECTIONS
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().keys().hasAll(['uid', 'email']) && incoming().keys().size() >= 2;
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().uid == existing().uid
        && incoming().email == existing().email;
    }

    match /tasks/{taskId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(taskId) && isValidTask(incoming()) 
        && incoming().createdAt == request.time
        && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidTask(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /thoughts/{thoughtId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(thoughtId) && isValidThought(incoming()) 
        && incoming().createdAt == request.time
        && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidThought(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /focus_sessions/{sessionId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(sessionId) && isValidFocusSession(incoming()) 
        && incoming().createdAt == request.time
        && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidFocusSession(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /growth_areas/{areaId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(areaId) && isValidGrowthArea(incoming()) 
        && incoming().createdAt == request.time
        && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidGrowthArea(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
